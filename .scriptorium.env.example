# Optional project preferences for Scriptorium.
# Copy to .scriptorium.env in a manuscript folder and enable project preferences in Settings.

SCRIPTORIUM_DEFAULT_PROVIDER=openai-subscription
SCRIPTORIUM_OPENAI_MODEL=gpt-5.5
SCRIPTORIUM_OPENAI_EFFORT=medium
SCRIPTORIUM_ANTHROPIC_MODEL=sonnet
SCRIPTORIUM_ANTHROPIC_EFFORT=medium
SCRIPTORIUM_LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
SCRIPTORIUM_LM_STUDIO_MODEL=local-model
SCRIPTORIUM_THEME=paper
SCRIPTORIUM_EDITOR_FONT=literary
SCRIPTORIUM_EDITOR_FONT_SIZE=18
SCRIPTORIUM_EDITOR_LINE_WIDTH=760
